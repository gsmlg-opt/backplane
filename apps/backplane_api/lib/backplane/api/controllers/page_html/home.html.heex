<div class="min-h-full bg-surface text-on-surface">
  <.dm_appbar
    title="Backplane"
    title_to={~p"/"}
    class="appbar-primary appbar-elevated border-b border-outline-variant"
    nav_label="Backplane public gateway"
  >
    <:user_profile>
      <div class="hidden items-center gap-2 sm:flex">
        <.dm_badge variant="info" size="sm" soft>Public API</.dm_badge>
        <.dm_badge variant="success" size="sm" soft>MCP Hub</.dm_badge>
        <nav class="appbar-actions" aria-label="Backplane public gateway">
          <.dm_tooltip content="Endpoints" position="bottom" class="inline-flex">
            <a href="/#endpoints" class="appbar-action" aria-label="Endpoints">
              <.dm_mdi name="api" class="h-5 w-5" />
              <span class="sr-only">Endpoints</span>
            </a>
          </.dm_tooltip>
          <.dm_tooltip content="Clients" position="bottom" class="inline-flex">
            <a href="/#clients" class="appbar-action" aria-label="Clients">
              <.dm_mdi name="console" class="h-5 w-5" />
              <span class="sr-only">Clients</span>
            </a>
          </.dm_tooltip>
          <.dm_tooltip content="Health" position="bottom" class="inline-flex">
            <a href="/#health" class="appbar-action" aria-label="Health">
              <.dm_mdi name="heart-pulse" class="h-5 w-5" />
              <span class="sr-only">Health</span>
            </a>
          </.dm_tooltip>
        </nav>
        <.dm_tooltip content="Theme" position="bottom">
          <details
            id="home-theme-switcher"
            class="theme-controller-dropdown theme-controller-dropdown-end theme-controller-dropdown-icon"
            phx-hook="ThemeSwitcher"
            data-theme="moonlight"
          >
            <summary
              class="theme-controller-trigger"
              aria-label="Select theme"
              aria-haspopup="menu"
            >
              <.dm_mdi name="theme-light-dark" class="h-5 w-5" />
              <span class="sr-only">Theme</span>
            </summary>
            <div class="theme-controller-menu" role="radiogroup" aria-label="Select theme">
              <input
                type="radio"
                id="home-theme-switcher-default"
                name="theme-home-theme-switcher"
                class="theme-controller-item"
                value="default"
              />
              <label for="home-theme-switcher-default" class="theme-controller-label">
                Auto
              </label>
              <input
                type="radio"
                id="home-theme-switcher-sunshine"
                name="theme-home-theme-switcher"
                class="theme-controller-item"
                value="sunshine"
              />
              <label for="home-theme-switcher-sunshine" class="theme-controller-label">
                Sunshine
              </label>
              <input
                type="radio"
                id="home-theme-switcher-moonlight"
                name="theme-home-theme-switcher"
                class="theme-controller-item"
                value="moonlight"
                checked
              />
              <label for="home-theme-switcher-moonlight" class="theme-controller-label">
                Moonlight
              </label>
            </div>
          </details>
        </.dm_tooltip>
      </div>
    </:user_profile>
  </.dm_appbar>

  <div id="home-body" class="mx-auto max-w-7xl">
    <header class="border-b border-outline-variant bg-surface-container-low">
      <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:px-6 lg:grid-cols-[1fr_18rem] lg:px-8">
        <div class="max-w-3xl">
          <div class="flex flex-wrap gap-2">
            <.dm_badge variant="primary" soft>Backplane Gateway</.dm_badge>
            <.dm_badge variant="secondary" soft>Self-hosted edge</.dm_badge>
          </div>
          <h1 class="mt-4 text-3xl font-bold tracking-normal text-on-surface sm:text-4xl">
            One public surface for agents, tools, and model traffic
          </h1>
          <p class="mt-4 max-w-2xl text-base leading-7 text-on-surface-variant">
            Use this endpoint as the stable entry point for MCP sessions and LLM API calls. Backplane
            keeps client configuration compact while routing requests to the services behind it.
          </p>
          <div class="mt-6 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-md border border-outline-variant bg-surface p-4">
              <div class="font-semibold text-on-surface">MCP</div>
              <div class="mt-2 space-y-1 text-xs leading-5">
                <code class="block text-primary">POST /mcp</code>
                <code class="block text-primary">GET /mcp</code>
                <code class="block text-primary">DELETE /mcp</code>
              </div>
            </div>
            <div class="rounded-md border border-outline-variant bg-surface p-4">
              <div class="font-semibold text-on-surface">LLM proxy</div>
              <div class="mt-2 space-y-1 text-xs leading-5">
                <code class="block text-primary">GET /v1/models</code>
                <code class="block text-primary">POST /v1/messages</code>
                <code class="block text-primary">POST /v1/chat/completions</code>
                <code class="block text-primary">POST /v1/responses</code>
                <code class="block text-primary">POST /v1/embeddings</code>
              </div>
            </div>
            <div class="rounded-md border border-outline-variant bg-surface p-4">
              <div class="font-semibold text-on-surface">Provider API</div>
              <div class="mt-2 space-y-1 text-xs leading-5">
                <code class="block text-primary">/llm/providers</code>
                <code class="block text-primary">/llm/aliases</code>
              </div>
            </div>
            <div class="rounded-md border border-outline-variant bg-surface p-4">
              <div class="font-semibold text-on-surface">Skills and runtime</div>
              <div class="mt-2 space-y-1 text-xs leading-5">
                <code class="block text-primary">/skills</code>
                <code class="block text-primary">/host-agent/socket</code>
                <code class="block text-primary">/health</code>
                <code class="block text-primary">/metrics</code>
              </div>
            </div>
          </div>
        </div>

        <div class="flex items-center justify-center lg:justify-end">
          <div class="relative aspect-square w-52 rounded-lg border border-outline-variant bg-surface p-8 shadow-sm">
            <div class="absolute inset-x-8 top-8 h-px bg-outline-variant"></div>
            <div class="absolute inset-y-8 left-8 w-px bg-outline-variant"></div>
            <img
              src={~p"/images/backplane-icon.png"}
              alt="Backplane"
              class="relative z-10 h-full w-full object-contain"
            />
          </div>
        </div>
      </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
      <section id="endpoints" class="scroll-mt-24">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-semibold">All API endpoints</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-on-surface-variant">
              These routes are the external contract for clients. They cover MCP sessions, model proxying,
              provider metadata, skill archives, host-agent sockets, health checks, and metrics.
            </p>
          </div>
          <.dm_badge variant="primary" soft>Complete catalog</.dm_badge>
        </div>

        <div class="grid gap-4 lg:grid-cols-2">
          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span>MCP session API</span>
                <.dm_badge variant="success" size="sm">/mcp</.dm_badge>
              </div>
            </:title>
            <div class="mt-4 space-y-2 text-sm leading-6 text-on-surface-variant">
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/mcp</code>
                  <p>JSON-RPC requests: initialize, tools/list, tools/call, ping.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/mcp</code>
                  <p>Server-sent event stream for MCP notifications.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="error" size="sm">DELETE</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/mcp</code>
                  <p>Session cleanup for clients that maintain an MCP session id.</p>
                </div>
              </div>
            </div>
          </.dm_card>

          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span>LLM proxy API</span>
                <.dm_badge variant="secondary" size="sm">/v1</.dm_badge>
              </div>
            </:title>
            <div class="mt-4 space-y-2 text-sm leading-6 text-on-surface-variant">
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/models</code>
                  <p>OpenAI-format list of exposed models and aliases.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/messages</code>
                  <p>Anthropic Messages-compatible request proxy.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/chat/completions</code>
                  <p>OpenAI Chat Completions-compatible request proxy.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/responses</code>
                  <p>OpenAI Responses-compatible request proxy.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/embeddings</code>
                  <p>OpenAI Embeddings-compatible request proxy.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/v1/*</code>
                  <p>OpenAI-compatible fallback proxy for other provider paths.</p>
                </div>
              </div>
            </div>
          </.dm_card>

          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span>LLM provider API</span>
                <.dm_badge variant="tertiary" size="sm">/llm</.dm_badge>
              </div>
            </:title>
            <div class="mt-4 space-y-2 text-sm leading-6 text-on-surface-variant">
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/providers</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/providers</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/providers/:id</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="warning" size="sm">PATCH</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/providers/:id</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="error" size="sm">DELETE</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/providers/:id</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/aliases</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/aliases</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="error" size="sm">DELETE</.dm_badge>
                <code class="font-semibold text-on-surface">/llm/aliases/:id</code>
              </div>
            </div>
          </.dm_card>

          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span>Skills API</span>
                <.dm_badge variant="primary" size="sm">/skills</.dm_badge>
              </div>
            </:title>
            <div class="mt-4 space-y-2 text-sm leading-6 text-on-surface-variant">
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/skills</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <code class="font-semibold text-on-surface">/skills</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/skills/export</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="success" size="sm">POST</.dm_badge>
                <code class="font-semibold text-on-surface">/skills/import</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/skills/:slug</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <code class="font-semibold text-on-surface">/skills/:slug/archive</code>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="error" size="sm">DELETE</.dm_badge>
                <code class="font-semibold text-on-surface">/skills/:slug</code>
              </div>
            </div>
          </.dm_card>

          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center justify-between gap-3">
                <span>Host-agent and runtime endpoints</span>
                <.dm_badge variant="info" size="sm">runtime</.dm_badge>
              </div>
            </:title>
            <div class="mt-4 space-y-2 text-sm leading-6 text-on-surface-variant">
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="secondary" size="sm">WS</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/host-agent/socket</code>
                  <p>Host-agent manager WebSocket.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/health</code>
                  <p>JSON health check.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/metrics</code>
                  <p>JSON runtime metrics snapshot.</p>
                </div>
              </div>
              <div class="grid gap-2 rounded-md bg-surface-container p-3 sm:grid-cols-[4.5rem_1fr]">
                <.dm_badge variant="info" size="sm">GET</.dm_badge>
                <div>
                  <code class="font-semibold text-on-surface">/metrics/prometheus</code>
                  <p>Prometheus text exposition format.</p>
                </div>
              </div>
            </div>
          </.dm_card>
        </div>
      </section>

      <section id="clients" class="mt-10 scroll-mt-24">
        <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
          <div>
            <h2 class="text-2xl font-semibold">Client configuration</h2>
            <p class="mt-2 max-w-3xl text-sm leading-6 text-on-surface-variant">
              Point coding agents and API clients at this server. Add bearer tokens only when this
              deployment requires them.
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <.dm_badge variant="secondary" soft>Model gateway</.dm_badge>
            <.dm_badge variant="success" soft>Tool gateway</.dm_badge>
          </div>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center gap-3">
                <span>Claude Code</span>
                <.dm_badge variant="tertiary" size="sm">Anthropic wire API</.dm_badge>
              </div>
            </:title>

            <div class="space-y-4 text-sm leading-6 text-on-surface-variant">
              <p>
                Use the Anthropic-compatible base URL without <code class="text-on-surface">/v1</code>.
                Claude Code appends its message path when sending requests.
              </p>
              <pre class="overflow-x-auto rounded-md bg-surface-container-high p-4 text-xs leading-5 text-on-surface"><code>export ANTHROPIC_BASE_URL="{@base_url}"
export ANTHROPIC_API_KEY="bk-client-token"
claude</code></pre>
              <p>
                Add the MCP endpoint as an HTTP server. Include an authorization header when this
                gateway expects client authentication.
              </p>
              <pre class="overflow-x-auto rounded-md bg-surface-container-high p-4 text-xs leading-5 text-on-surface"><code>claude mcp add --transport http backplane {@base_url}/mcp

claude mcp add-json backplane \
'&#123;"type":"http","url":"{@base_url}/mcp","headers":&#123;"Authorization":"Bearer YOUR_MCP_TOKEN"&#125;&#125;'</code></pre>
            </div>

            <:action>
              <a href="https://code.claude.com/docs/en/env-vars" class="no-underline">
                <.dm_btn variant="outline" size="sm">Claude env docs</.dm_btn>
              </a>
            </:action>
          </.dm_card>

          <.dm_card variant="bordered" padding="lg">
            <:title>
              <div class="flex flex-wrap items-center gap-3">
                <span>Codex</span>
                <.dm_badge variant="info" size="sm">OpenAI-compatible config</.dm_badge>
              </div>
            </:title>

            <div class="space-y-4 text-sm leading-6 text-on-surface-variant">
              <p>
                Configure Codex in <code class="text-on-surface">~/.codex/config.toml</code>. Use
                <code class="text-on-surface">openai_base_url</code> for model traffic and
                <code class="text-on-surface">mcp_servers</code> for the tool gateway.
              </p>
              <pre class="overflow-x-auto rounded-md bg-surface-container-high p-4 text-xs leading-5 text-on-surface"><code>openai_base_url = "{@base_url}/v1"

[mcp_servers.backplane]
url = "{@base_url}/mcp"

# When bearer tokens are required:
bearer_token_env_var = "BACKPLANE_MCP_TOKEN"</code></pre>
              <pre class="overflow-x-auto rounded-md bg-surface-container-high p-4 text-xs leading-5 text-on-surface"><code>export OPENAI_API_KEY="bk-client-token"
export BACKPLANE_MCP_TOKEN="YOUR_MCP_TOKEN"
codex</code></pre>
            </div>

            <:action>
              <a href="https://developers.openai.com/codex/config-reference" class="no-underline">
                <.dm_btn variant="outline" size="sm">Codex config docs</.dm_btn>
              </a>
            </:action>
          </.dm_card>
        </div>
      </section>

      <section id="health" class="mt-10 scroll-mt-24">
        <div class="grid gap-4 lg:grid-cols-[1fr_1fr_1fr]">
          <.dm_card variant="bordered" padding="lg">
            <:title>Health check</:title>
            <p class="mt-3 text-sm leading-6 text-on-surface-variant">
              Poll <code class="text-on-surface">/health</code> for availability checks.
            </p>
          </.dm_card>
          <.dm_card variant="bordered" padding="lg">
            <:title>Metrics</:title>
            <p class="mt-3 text-sm leading-6 text-on-surface-variant">
              Scrape <code class="text-on-surface">/metrics</code> for runtime metrics.
            </p>
          </.dm_card>
          <.dm_card variant="bordered" padding="lg">
            <:title>Model discovery</:title>
            <p class="mt-3 text-sm leading-6 text-on-surface-variant">
              Use <code class="text-on-surface">/v1/models</code> to discover exposed models.
            </p>
          </.dm_card>
        </div>
      </section>
    </main>
  </div>

  <.dm_page_footer
    label="Backplane footer"
    class="border-t border-outline-variant bg-secondary text-secondary-content py-8"
  >
    <:section class="md:col-span-2" body_class="gap-3" title="Public gateway contract">
      <div class="flex flex-wrap gap-2">
        <.dm_badge variant="primary" soft>One MCP endpoint</.dm_badge>
        <.dm_badge variant="tertiary" soft>One model gateway</.dm_badge>
      </div>
      <p class="max-w-2xl text-sm leading-6 text-secondary-content">
        Keep agents connected to stable public routes while Backplane handles routing, credentials,
        model aliases, tool namespaces, and usage capture behind the gateway.
      </p>
    </:section>
    <:section title="Routes" body_class="gap-2 text-sm">
      <code class="text-secondary-content">POST /mcp</code>
      <code class="text-secondary-content">GET /mcp</code>
      <code class="text-secondary-content">DELETE /mcp</code>
      <code class="text-secondary-content">GET /v1/models</code>
