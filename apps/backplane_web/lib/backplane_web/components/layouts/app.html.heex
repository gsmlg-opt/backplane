<div class="min-h-full">
  <.dm_appbar title="Backplane" title_to={~p"/admin"} class="appbar-primary">
    <:menu to={~p"/admin"} active={@current_path == "/admin"}>Dashboard</:menu>
    <:menu to={~p"/admin/hub"} active={String.starts_with?(@current_path, "/admin/hub")}>MCP Hub</:menu>
    <:menu to={~p"/admin/providers"} active={String.starts_with?(@current_path, "/admin/providers")}>LLM Providers</:menu>
    <:menu to={~p"/admin/clients"} active={String.starts_with?(@current_path, "/admin/clients")}>Clients</:menu>
    <:menu to={~p"/admin/logs"} active={String.starts_with?(@current_path, "/admin/logs")}>Logs</:menu>
    <:menu to={~p"/admin/settings"} active={String.starts_with?(@current_path, "/admin/settings")}>Settings</:menu>
  </.dm_appbar>

  <main>
    <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
      <.dm_flash_group flash={@flash} />
      {@inner_content}
    </div>
  </main>
</div>
