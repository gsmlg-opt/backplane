[backplane]
host = "0.0.0.0"
port = 4100
# Optional: require bearer token from MCP clients
# auth_token = "your-backplane-secret"
# Or use a list for token rotation:
# auth_tokens = ["current-token", "previous-token"]

[database]
url = "postgres://localhost/backplane_dev"

# --- Git Platform Credentials ---

[github]
token = "ghp_..."
api_url = "https://api.github.com"

[gitlab]
token = "glpat-..."
api_url = "https://gitlab.com/api/v4"

# --- Projects to Index ---

# [[projects]]
# id = "my-project"
# repo = "github:org/repo"
# ref = "main"
# parsers = ["elixir", "markdown"]
# reindex_interval = "1h"

# --- Upstream MCP Servers to Proxy ---

# [[upstream]]
# name = "filesystem"
# transport = "stdio"
# command = "npx"
# args = ["-y", "@anthropic/mcp-filesystem"]
# prefix = "fs"
# timeout = 30000              # Tool call timeout in ms (default: 30000)
# refresh_interval = 300000    # Tool discovery refresh in ms (default: 300000)

# [[upstream]]
# name = "postgres-mcp"
# transport = "http"
# url = "http://localhost:4200/mcp"
# prefix = "pg"
# timeout = 60000              # Longer timeout for DB queries

